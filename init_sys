    mu_a, mu_b = params_a[0], params_b[0]

    mult_a = narrative_team.get((stat, team_a), 1.00)

    mult_b = narrative_team.get((stat, team_b), 1.00)

    return (mu_a * mult_a + mu_b * mult_b) / (mu_a + mu_b)

