**2. Venue-Aware Parameter Blending**



```python

def get_blended_params(player, category, tonight_venue, min_mins=20):

    """

    Venue-blended parameter estimation with proportional weighting.

    Weight given to venue split scales with n_ven; never exceeds 50%.

    All-zero venue splits with n_ven < 6 are overridden to all-games only.



    Returns: (mu_all, mu_blend, s2_blend, n_all, n_venue, blend_flag)

    """

    sub = player_df[(player_df['Player'] == player) &

                    (player_df['Category'] == category) &

                    (player_df['Minutes'] >= min_mins)]



    all_games   = sub['Main'].dropna()

    venue_split = sub[sub['Venue'] == tonight_venue]['Main'].dropna()



    n_all = len(all_games); n_ven = len(venue_split)

    if n_all < 3: return None



    mu_all = all_games.mean()

    s2_all = all_games.var(ddof=1) if n_all > 1 else mu_all + 0.01



    if n_ven < 3:

        mu_blend, s2_blend = mu_all, s2_all

        blend_flag = f"n_ven={n_ven}<3 → all-games only"

    else:

        mu_ven = venue_split.mean()

        s2_ven = venue_split.var(ddof=1) if n_ven > 1 else mu_ven + 0.01



        # ALL-ZERO VENUE GUARD:

        if mu_ven == 0.0 and n_ven < 6:

            mu_blend, s2_blend = mu_all, s2_all

            blend_flag = (f"ALL-ZERO VENUE OVERRIDE n_ven={n_ven}, "

                          f"mu_ven=0.0 → reverting to mu_all={mu_all:.4f}")

        else:

            weight_ven = min(n_ven / 10.0, 0.50)

            weight_all = 1.0 - weight_ven

            mu_blend = weight_all * mu_all + weight_ven * mu_ven

            s2_blend = weight_all * s2_all + weight_ven * s2_ven

            blend_flag = (f"n_ven={n_ven}, w_ven={weight_ven:.2f}, "

                          f"mu_ven={mu_ven:.4f} → mu_blend={mu_blend:.4f}")



    mu_blend = max(0.01, mu_blend)

    s2_blend = max(mu_blend + 0.01, s2_blend)



    return mu_all, mu_blend, s2_blend, n_all, n_ven, blend_flag

```



