def ftg_to_anytime(p_first, lambda_match):

    """

    Converts P(first scorer) → P(anytime scorer ≥ 1).

    """

    if lambda_match <= 0:

        return p_first

    correction = lambda_match / (1.0 - math.exp(-lambda_match))

    p_anytime = min(0.99, p_first * correction)

    print(f"[FTG PROXY] P(first)={p_first:.4f} | λ_match={lambda_match:.3f} | "

          f"correction={correction:.3f} | P(anytime)={p_anytime:.4f}")

    if p_anytime > 0.60:

        print(f"  ⚠️ P(anytime) > 0.60 — manual sanity check required")

    return p_anytime

```



